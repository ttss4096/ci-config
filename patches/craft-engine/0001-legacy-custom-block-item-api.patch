+package net.momirealms.craftengine.core.block;
+
+/**
+ * Legacy compatibility alias for {@link BlockDefinition}.
+ * Retained for binary compatibility with plugins compiled against older CE APIs
+ * (e.g. ValhallaMMO 1.9.3).
